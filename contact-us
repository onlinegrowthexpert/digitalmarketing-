<!-- ============ CONTACT ============ -->
<section id="contact" class="section section--dark">
  <div class="container contact-grid">

    <div class="reveal">
      <p class="eyebrow">SEND A MESSAGE</p>
      <h2>Tell us about your business. We'll tell you what we'd do first.</h2>

      <form
        class="contact-form"
        action="https://formsubmit.co/webdevelopmentandigitalmarket@gmail.com"
        method="POST"
      >
        <div class="form-row">
          <div class="form-field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-field">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-field">
            <label for="service">Service Interested In</label>
            <select id="service" name="service">
              <option>SEO Services</option>
              <option>Website Development</option>
              <option>Paid Ads</option>
              <option>Social Media (SMO)</option>
              <option>App Development</option>
              <option>Digital Marketing Course</option>
              <option>Something else</option>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="4" required></textarea>
        </div>

        <!-- Hidden Fields -->
        <input type="hidden" name="_subject" value="New Lead From Contact Page">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_next" value="https://onlinegrowthexpert.github.io/digitalmarketing/thankyou-page.html">

        <button type="submit" class="btn btn--primary">Send Message</button>
        <p class="form-success" id="form-success" hidden>Thanks — we've received your message and will get back to you shortly.</p>
      </form>
    </div>

    <div class="contact-info reveal">
